#!/usr/bin/env python3
"""Deep-scrape incitement data including quotes from each person's detail page."""
import json
import re
import sys
import time
from urllib.request import urlopen, Request
from html.parser import HTMLParser
from html import unescape

BASE = "https://stopmurderingjournalists.com"

def fetch(path):
    url = path if path.startswith("http") else f"{BASE}{path}"
    req = Request(url, headers={"User-Agent": "Mozilla/5.0 (compatible; research bot)"})
    with urlopen(req, timeout=15) as resp:
        return resp.read().decode("utf-8", errors="replace")

# ---- List parsers (same as before) ----
class PeopleListParser(HTMLParser):
    def __init__(self):
        super().__init__()
        self.people = []
        self._in_li = False
        self._in_h3 = False
        self._in_p = False
        self._cur = {}
        self._h3 = ""
        self._p = ""
    def handle_starttag(self, tag, attrs):
        d = dict(attrs)
        if tag == "li": self._in_li = True; self._cur = {}
        if self._in_li and tag == "a":
            href = d.get("href","")
            if "/incitement/people/" in href:
                self._cur["url"] = href; self._cur["id"] = href.rstrip("/").split("/")[-1]
        if self._in_li and tag == "img" and "Image of" in d.get("alt",""):
            self._cur["image"] = d.get("src","")
        if self._in_li and tag == "h3": self._in_h3 = True; self._h3 = ""
        if self._in_li and tag == "p" and "text-gray-600" in d.get("class",""): self._in_p = True; self._p = ""
    def handle_endtag(self, tag):
        if tag == "h3" and self._in_h3:
            self._in_h3 = False
            m = re.match(r'(.+?)\s*\((\d+)\)', self._h3.strip())
            if m: self._cur["name"] = m.group(1).strip(); self._cur["incitement_count"] = int(m.group(2))
            else: self._cur["name"] = self._h3.strip(); self._cur["incitement_count"] = 0
        if tag == "p" and self._in_p: self._in_p = False; self._cur["role"] = self._p.strip()
        if tag == "li" and self._in_li:
            self._in_li = False
            if self._cur.get("name"): self.people.append(self._cur)
    def handle_data(self, data):
        if self._in_h3: self._h3 += data
        if self._in_p: self._p += data

